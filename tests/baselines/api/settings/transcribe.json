{
  "api_keys": {
    "gemini": false,
    "parakeet": false,
    "revai": false,
    "whisper": false
  },
  "backends": [
    {
      "description": "Cloud-based transcription with speaker identification",
      "env_key": "GOOGLE_API_KEY",
      "label": "Gemini - Cloud with speaker diarization",
      "name": "gemini",
      "settings": []
    },
    {
      "description": "Cloud-based transcription with speaker identification",
      "env_key": "REVAI_ACCESS_TOKEN",
      "label": "Rev.ai - Cloud with speaker diarization",
      "name": "revai",
      "settings": [
        "model"
      ]
    },
    {
      "description": "Local speech recognition using faster-whisper",
      "env_key": null,
      "label": "Whisper - Local processing",
      "name": "whisper",
      "settings": [
        "device",
        "model",
        "compute_type"
      ]
    },
    {
      "description": "On-device speech recognition via Parakeet TDT; macOS uses a FluidAudio/CoreML helper, Linux uses NeMo + torch. Requires `make install`.",
      "env_key": null,
      "label": "Parakeet - Local processing (Apple Silicon CoreML or Linux NeMo)",
      "name": "parakeet",
      "settings": [
        "model_version",
        "device",
        "timeout_sec"
      ]
    }
  ],
  "config": {
    "backend": "parakeet",
    "enrich": true,
    "noise_upgrade": true,
    "parakeet": {
      "device": "auto",
      "model_version": "v3",
      "timeout_sec": 120.0
    },
    "revai": {
      "model": "fusion"
    },
    "whisper": {
      "compute_type": "default",
      "device": "auto",
      "model": "medium.en"
    }
  },
  "runtime_label": "Linux NeMo (CUDA fp16)"
}
