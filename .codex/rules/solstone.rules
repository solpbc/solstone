# Execution policy rules for solstone agent CLI commands.
# Allows "sol" commands to run outside the sandbox without prompting.
# See: https://developers.openai.com/codex/exec-policy

prefix_rule(
    pattern=["sol"],
    decision="allow",
    justification="sol invokes journal query, agent, and diagnostic commands",
    match=["sol call todos list", "sol call entities list", "sol health", "sol muse logs"],
    not_match=["solc", "solid"],
)
