{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Output contract for detect_transcript_segment(). Source of truth is think/detect_transcript_segment.md.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["start_at", "line"],
    "properties": {
      "start_at": {"type": "string", "pattern": "^\\d{2}:\\d{2}:\\d{2}$"},
      "line": {"type": "integer", "minimum": 1}
    }
  }
}
