{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["message", "notes", "talent_request"],
  "properties": {
    "message": {"type": ["string", "null"]},
    "notes": {"type": "string"},
    "talent_request": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["target", "task"],
          "properties": {
            "target": {
              "type": "string",
              "enum": ["exec", "reflection"]
            },
            "task": {"type": "string", "minLength": 1},
            "context": {"type": "object"}
          }
        }
      ]
    }
  }
}
