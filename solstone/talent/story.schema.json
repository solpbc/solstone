{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["body","topics","confidence","commitments","closures","decisions"],
  "properties": {
    "body": {"type": "string", "minLength": 1},
    "topics": {
      "type": "array",
      "items": {"type": "string"},
      "maxItems": 10
    },
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "commitments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["owner","action","counterparty","when","context"],
        "properties": {
          "owner": {"type": "string", "minLength": 1},
          "action": {"type": "string", "minLength": 1},
          "counterparty": {"type": "string", "minLength": 1},
          "when": {"type": "string", "minLength": 1},
          "context": {"type": "string", "minLength": 1}
        }
      }
    },
    "closures": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["owner","action","counterparty","resolution","context"],
        "properties": {
          "owner": {"type": "string", "minLength": 1},
          "action": {"type": "string", "minLength": 1},
          "counterparty": {"type": "string", "minLength": 1},
          "resolution": {
            "type": "string",
            "enum": ["sent","done","signed","dropped","deferred"]
          },
          "context": {"type": "string", "minLength": 1}
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["owner","action","context"],
        "properties": {
          "owner": {"type": "string", "minLength": 1},
          "action": {"type": "string", "minLength": 1},
          "context": {"type": "string", "minLength": 1}
        }
      }
    }
  }
}
